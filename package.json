{
    "name": "python-copy-qualified-name",
    "displayName": "Python Copy Qualified Name",
    "description": "Copy fully qualified Python method and function names to clipboard",
    "version": "1.3.26",
    "publisher": "DoctorC",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/nidheesh-doctorc/vscode-copy-python-fqn.git"
    },
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onLanguage:python",
        "onTaskType:hostScript"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "configuration": {
            "title": "Python Copy Qualified Name",
            "properties": {
                "pythonCopyQualifiedName.fileMonitor.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable monitoring of open Python files"
                },
                "pythonCopyQualifiedName.fileMonitor.checkInterval": {
                    "type": "number",
                    "default": 10,
                    "description": "Interval in minutes to check for open Python files"
                },
                "pythonCopyQualifiedName.fileMonitor.maxFiles": {
                    "type": "number",
                    "default": 20,
                    "description": "Maximum number of Python files that should be open before showing a warning"
                },
                "pythonCopyQualifiedName.hostScripts.host": {
                    "type": "string",
                    "default": "",
                    "description": "Hostname of the host task server. Leave empty to auto-detect (localhost on host, host.docker.internal in devcontainer)"
                },
                "pythonCopyQualifiedName.hostScripts.port": {
                    "type": "number",
                    "default": 7890,
                    "description": "Port the host task server listens on"
                },
                "pythonCopyQualifiedName.hostScripts.hostWorkspacePath": {
                    "type": "string",
                    "default": "",
                    "description": "The host-side filesystem path of this workspace. Required when running inside a devcontainer (e.g. /Users/you/src/project). Leave empty when on the host."
                },
                "pythonCopyQualifiedName.worktreeIdentity.mode": {
                    "type": "string",
                    "enum": [
                        "workspaceSettings",
                        "statusBar",
                        "off"
                    ],
                    "enumDescriptions": [
                        "Update the workspace window title and title bar colors by writing workspace settings.",
                        "Show the worktree identity in a session-only status bar item without modifying workspace files.",
                        "Do not show the worktree identity."
                    ],
                    "default": "workspaceSettings",
                    "scope": "machine",
                    "description": "Controls how worktree identity is shown. Use statusBar to avoid Git-visible workspace setting changes."
                },
                "pythonCopyQualifiedName.worktreeIdentity.windowTitleTemplate": {
                    "type": "string",
                    "default": "worktree: ${worktreeName} / ${activeRepositoryBranchName}",
                    "scope": "machine",
                    "description": "Template used for the VS Code window title when worktree identity mode is workspaceSettings. Supports the additional ${worktreeName} placeholder."
                }
            }
        },
        "taskDefinitions": [
            {
                "type": "hostScript",
                "required": ["command"],
                "properties": {
                    "command": {
                        "type": "string",
                        "description": "Shell command to execute on the host machine"
                    },
                    "args": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Extra arguments passed to the command"
                    },
                    "options": {
                        "type": "object",
                        "description": "Execution options for the host task",
                        "properties": {
                            "cwd": {
                                "type": "string",
                                "description": "Working directory for the host task"
                            },
                            "env": {
                                "type": "object",
                                "description": "Environment variables for the host task",
                                "additionalProperties": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        ],
        "commands": [
            {
                "command": "python-copy-qualified-name.copyQualifiedName",
                "title": "Copy As Fully Qualified Name"
            },
            {
                "command": "python-copy-qualified-name.hostScripts.list",
                "title": "Host Scripts: List Available Tasks"
            },
            {
                "command": "python-copy-qualified-name.hostScripts.run",
                "title": "Host Scripts: Run Task"
            },
            {
                "command": "python-copy-qualified-name.hostScripts.runByName",
                "title": "Host Scripts: Run Task by Label"
            },
            {
                "command": "python-copy-qualified-name.hostScripts.status",
                "title": "Host Scripts: Check Server Status"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "python-copy-qualified-name.copyQualifiedName",
                    "when": "editorTextFocus && resourceExtname == .py",
                    "group": "navigation"
                }
            ]
        },
        "keybindings": [
            {
                "command": "python-copy-qualified-name.copyQualifiedName",
                "key": "cmd+alt+c",
                "when": "editorTextFocus && resourceExtname == .py"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "16.x",
        "typescript": "^4.9.4"
    }
}